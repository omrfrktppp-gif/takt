# Google Search Console — HTML etiketi content değeri (tırnaksız)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — msvalidate.01 content değeri
BING_MSVALIDATE=

# IndexNow API koruması — /api/indexnow POST için Bearer token
INDEXNOW_API_SECRET=

# IndexNow anahtarı — varsayılan projede tanımlı; değiştirmeyin
# INDEXNOW_KEY=a8f3c2e1b9d0475682acf1e03b4d1597

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-PB25P347

# Web3Forms — tarayıcıdan doğrudan gönderim (ZORUNLU, ücretsiz plan)
# Panel: https://web3forms.com → Access Key → Domain Restrictions: takt.tr
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Eski sunucu proxy (ücretsiz planda ÇALIŞMAZ — Pro gerekir)
# WEB3FORMS_ACCESS_KEY=

# Başlangıç formu yükleme → Google Drive (docs/13-baslangic-formu-drive-kurulum.md)
GOOGLE_DRIVE_FOLDER_ID=1YA9TvB55atwCQSA_vOBR_tTzo1xc5kbf
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
