# Google Search Console — HTML etiketi content değeri (tırnaksız)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools — msvalidate.01 content değeri
BING_MSVALIDATE=

# IndexNow API koruması — /api/indexnow POST için Bearer token
INDEXNOW_API_SECRET=

# IndexNow anahtarı — varsayılan projede tanımlı; değiştirmeyin
# INDEXNOW_KEY=a8f3c2e1b9d0475682acf1e03b4d1597

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-PB25P347

# Web3Forms — iletişim formu (sunucu tarafı, client'a gitmez)
WEB3FORMS_ACCESS_KEY=01980218-5dbb-42ef-8b56-3fbc2c93d874
